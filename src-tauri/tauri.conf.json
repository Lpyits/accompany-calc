{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
  "productName": "陪玩系统",
  "version": "1.0.0",
  "identifier": "com.accompany.calc",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "薇薇陪玩",
        "width": 1000,
        "height": 750,
        "resizable": true,
        "minWidth": 1000,
        "minHeight": 750,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {}
}
